{
    "name": "chgold/xenforo-ai-connect",
    "description": "WebMCP protocol bridge for XenForo - enables AI agents to interact with your forum",
    "type": "xenforo2-addon",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "chgold",
            "email": "dev@chgold.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "firebase/php-jwt": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "chgold\\AIConnect\\": "src/addons/chgold/AIConnect/"
        }
    },
    "config": {
        "vendor-dir": "src/addons/chgold/AIConnect/vendor"
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"if (!file_exists('src/addons/chgold/AIConnect/vendor')) { mkdir('src/addons/chgold/AIConnect/vendor', 0755, true); }\""
        ]
    },
    "minimum-stability": "stable"
}
